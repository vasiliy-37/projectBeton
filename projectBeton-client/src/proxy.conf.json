{
  "/_recaptcha-proxy": {
    "target": "https://www.recaptcha.net",
    "secure": true,
    "changeOrigin": true,
    "pathRewrite": {
      "^/_recaptcha-proxy": ""
    },
    "logLevel": "warn"
  },
  "/api": {
    "target": "http://localhost:3000",
    "secure": false,
    "changeOrigin": true,
    "logLevel": "debug",
    "cookieDomainRewrite": false
  },
  "/uploads": {
    "target": "http://localhost:3000",
    "secure": false,
    "changeOrigin": true
  }
}