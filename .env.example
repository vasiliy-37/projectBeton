# Скопируйте в файл .env в ЭТОМ ЖЕ каталоге (рядом с docker-compose.yml).
# Docker Compose подставляет значения при `docker compose up`.
# Не коммитьте .env в git.

# Домены, с которых открывают сайт (Host / X-Forwarded-Host). Обязательно для Angular SSR в проде.
# Пример: betonstroy37.ru,www.betonstroy37.ru
NG_ALLOWED_HOSTS=betonstroy37.ru,www.betonstroy37.ru
