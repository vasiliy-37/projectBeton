# Скопируйте в .env и заполните. Не коммитьте .env в git.

# --- Обязательно в production ---
JWT_SECRET=
NODE_ENV=production

# MongoDB (в Docker compose MONGODB_URI задаётся из environment сервиса api)
MONGODB_URI=mongodb://localhost:27017/projectBeton

# Почта: SMTP Gmail (или другой) + куда слать заявки с сайта
EMAIL_USER=
EMAIL_PASS=
RECIPIENT_EMAIL=

# Яндекс SmartCaptcha (сайт: клиентский ключ в Angular src/app/smartcaptcha-client-key.ts или SMARTCAPTCHA_CLIENT_KEY в Docker web)
SMARTCAPTCHA_SERVER_KEY=

# CORS: точные origin фронта через запятую, напр. https://beton-stroy.ru,https://www.beton-stroy.ru
# В продакшене задайте явно (браузер шлёт Origin при кросс-доменных запросах к API на :3000).
CORS_ORIGINS=

# Куда API редиректит не-/api GET (локально не нужен)
FRONTEND_URL=https://ваш-домен.ru

# За HTTPS reverse proxy (nginx): COOKIE_SECURE=true, TRUST_PROXY=1
COOKIE_SECURE=true
TRUST_PROXY=1
